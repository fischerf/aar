# ─────────────────────────────────────────────────────
# Signal MCP — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────

# URL of the running signal-cli REST API (required)
SIGNAL_API_URL=http://localhost:8080

# Your Signal phone number in E.164 format (required)
SIGNAL_PHONE_NUMBER=+15551234567

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
SIGNAL_LOG_LEVEL=INFO

# Optional: write logs to a file as well as stderr
# SIGNAL_LOG_FILE=~/.signal-mcp/signal-mcp.log

# Optional: path to the config JSON (default: ~/.signal-mcp/config.json)
# SIGNAL_MCP_CONFIG=~/.signal-mcp/config.json
