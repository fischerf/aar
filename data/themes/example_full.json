{
  "name": "midnight",
  "description": "Deep blue midnight with gold accents — all fields shown (tui + tui --fixed)",

  "assistant": {
    "title_style": "bold #e0c097",
    "border_style": "#e0c097",
    "padding": [1, 2]
  },
  "tool_call": {
    "title_style": "bold #6a8caf",
    "border_style": "#6a8caf",
    "padding": [0, 2]
  },
  "tool_result": {
    "title_style": "bold #7ec49d",
    "border_style": "#7ec49d",
    "padding": [0, 2]
  },
  "tool_error": {
    "title_style": "bold #e05561",
    "border_style": "#e05561",
    "padding": [0, 2]
  },
  "reasoning": {
    "title_style": "#5c6370",
    "border_style": "#5c6370",
    "padding": [0, 2]
  },
  "error": {
    "title_style": "bold #e05561",
    "border_style": "#e05561",
    "padding": [0, 2]
  },
  "welcome": {
    "title_style": "bold #e0c097",
    "border_style": "#6a8caf",
    "padding": [1, 2]
  },

  "prompt_style": "bold #e0c097",
  "dim_text": "#5c6370",
  "working_style": "italic #6a8caf",
  "path_highlight": "bold #7ec49d",
  "usage_style": "#5c6370",

  "badges": {
    "read": "#6a8caf",
    "write": "#e0c097",
    "execute": "#e05561",
    "network": "#7ec49d",
    "external": "#c678dd"
  },

  "header": {
    "background": "on #0d1117",
    "text_style": "bold #e0c097",
    "separator_style": "#5c6370",
    "provider_style": "bold #7ec49d",
    "tokens_style": "#6a8caf",
    "session_style": "#5c6370",
    "state_style": "bold #e0c097"
  },
  "footer": {
    "background": "on #0d1117",
    "text_style": "bold #e0c097",
    "separator_style": "#5c6370",
    "step_style": "#6a8caf",
    "theme_style": "#c678dd",
    "input_style": "bold #e0c097"
  },

  "fixed_layout": {
    "regions": [
      { "name": "header", "size": 3 },
      { "name": "body", "size": null },
      { "name": "input", "size": 3 },
      { "name": "footer", "size": 3 }
    ],
    "body_background": "#0d1117",
    "input_background": "#161b22",
    "selected_block_style": "on #1f2937",
    "scrollbar": {
      "enabled": true,
      "color": "#6a8caf",
      "color_hover": "#e0c097",
      "color_active": "#7ec49d",
      "background": "#0d1117",
      "background_hover": "#161b22",
      "background_active": "#161b22",
      "size": 2,
      "scroll_speed": 3
    }
  }
}
