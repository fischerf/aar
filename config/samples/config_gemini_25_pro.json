{
  "provider": {
    "name": "gemini",
    "model": "gemini-2.5-pro",
    "api_key": "",
    "temperature": 0.0,
    "max_tokens": 16384,
    "extra": {
      "thinking_budget": -1,
      "timeout": 180.0
    }
  },
  "tools": {
    "enabled_builtins": [
      "read_file",
      "write_file",
      "edit_file",
      "list_directory",
      "bash"
    ],
    "bash_default_timeout": 120,
    "command_timeout": 300,
    "max_output_chars": 50000
  },
  "safety": {
    "read_only": false,
    "require_approval_for_writes": true,
    "require_approval_for_execute": true,
    "denied_paths": [
      "/etc/shadow",
      "/etc/passwd",
      "/etc/sudoers",
      "/etc/sudoers.d/**",
      "**/.env",
      "**/.env.*",
      "**/credentials",
      "**/credentials.*",
      "**/secrets",
      "**/secrets.*",
      "**/*.pem",
      "**/*.key",
      "**/*.p12",
      "**/*.pfx",
      "**/.ssh/**",
      "**/id_rsa",
      "**/id_dsa",
      "**/id_ecdsa",
      "**/id_ed25519",
      "**/.aws/**",
      "**/.azure/**",
      "**/.config/gcloud/**",
      "**/.netrc",
      "**/.npmrc",
      "**/.pypirc"
    ],
    "allowed_paths": ["<cwd>/**"],
    "sandbox": {
      "mode": "local",
      "local": {},
      "linux": {
        "workspace": null,
        "max_memory_mb": 512
      },
      "windows": {
        "workspace": null,
        "max_memory_mb": 512,
        "max_processes": 10,
        "use_low_integrity": true
      },
      "wsl": {
        "distro": "aar-sandbox",
        "shell": "sh",
        "wsl_user": null,
        "restrict_to_workspace": true,
        "workspace": null,
        "install_path": null,
        "profile": null
      }
    },
    "log_all_commands": true,
    "acp_approval_timeout": 0.0
  },
  "tui": {
    "theme": "default",
    "layout": {}
  },
  "guardrails": {
    "max_tokens_recoveries": 2,
    "max_repeated_tool_steps": 3,
    "reserve_tokens": 512,
    "reserve_cost_fraction": 0.1
  },
  "max_steps": 50,
  "timeout": 0.0,
  "max_retries": 3,
  "streaming": true,
  "context_window": 1000000,
  "context_strategy": "sliding_window",
  "token_budget": 300000,
  "cost_limit": 10.0,
  "token_warning_threshold": 0.8,
  "cost_warning_threshold": 0.8,
  "session_dir": ".agent/sessions",
  "project_rules_dir": ".agent",
  "log_level": "WARNING"
}
