{
  "provider": {
    "name": "ollama",
    "model": "gemma4:e4b",
    "base_url": "http://localhost:11434",
    "temperature": 0.6,
    "max_tokens": 8192,
    "extra": {
      "num_ctx": 32768,
      "top_p": 0.95,
      "top_k": 64,
      "min_p": 0.0,
      "supports_reasoning": true,
      "supports_tools": true,
      "supports_vision": true,
      "keep_alive": "10m",
      "read_timeout": null
    }
  },
  "tools": {
    "enabled_builtins": [
      "read_file",
      "write_file",
      "edit_file",
      "list_directory",
      "bash"
    ],
    "bash_default_timeout": 120,
    "command_timeout": 300,
    "max_output_chars": 50000
  },
  "safety": {
    "read_only": false,
    "require_approval_for_writes": true,
    "require_approval_for_execute": true,
    "denied_paths": [
      "/etc/shadow",
      "/etc/passwd",
      "/etc/sudoers",
      "/etc/sudoers.d/**",
      "**/.env",
      "**/.env.*",
      "**/credentials",
      "**/credentials.*",
      "**/secrets",
      "**/secrets.*",
      "**/*.pem",
      "**/*.key",
      "**/*.p12",
      "**/*.pfx",
      "**/.ssh/**",
      "**/id_rsa",
      "**/id_dsa",
      "**/id_ecdsa",
      "**/id_ed25519",
      "**/.aws/**",
      "**/.azure/**",
      "**/.config/gcloud/**",
      "**/.netrc",
      "**/.npmrc",
      "**/.pypirc"
    ],
    "allowed_paths": ["<cwd>/**"],
    "sandbox": {
      "mode": "wsl",
      "wsl": {
        "profile": "~/.aar/distros/alpine-base.json"
      }
    },
    "log_all_commands": true,
    "acp_approval_timeout": 0.0
  },
  "tui": {
    "theme": "",
    "layout": {
      "reasoning": {
        "visible": false
      },
      "token_usage": {
        "visible": true
      },
      "welcome": {
        "visible": true
      },
      "extensions": {
        "metrics": {
          "visible": true
        },
        "custom_panel": {
          "visible": false
        }
      }
    }
  },
  "guardrails": {
    "max_tokens_recoveries": 2,
    "max_repeated_tool_steps": 3,
    "reserve_tokens": 1024,
    "reserve_cost_fraction": 0.15
  },
  "max_steps": 150,
  "timeout": 0.0,
  "max_retries": 3,
  "streaming": true,
  "context_window": 32768,
  "context_strategy": "sliding_window",
  "token_budget": 50000,
  "cost_limit": 0.0,
  "token_warning_threshold": 0.7,
  "cost_warning_threshold": 0.7,
  "session_dir": ".agent/sessions",
  "project_rules_dir": ".agent",
  "log_level": "WARNING"
}
