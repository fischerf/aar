{
  "provider": {
    "name": "anthropic",
    "model": "claude-sonnet-4-6",
    "temperature": 0.0,
    "max_tokens": 8192,
    "extra": {}
  },
  "tools": {
    "enabled_builtins": [
      "read_file",
      "write_file",
      "edit_file",
      "list_directory",
      "bash"
    ],
    "allowed_paths": [],
    "command_timeout": 30,
    "max_output_chars": 50000
  },
  "safety": {
    "read_only": false,
    "require_approval_for_writes": true,
    "require_approval_for_execute": true,
    "denied_paths": [
      "/etc/shadow",
      "/etc/passwd",
      "/etc/sudoers",
      "/etc/sudoers.d/**",
      "**/.env",
      "**/.env.*",
      "**/credentials",
      "**/credentials.*",
      "**/secrets",
      "**/secrets.*",
      "**/*.pem",
      "**/*.key",
      "**/*.p12",
      "**/*.pfx",
      "**/.ssh/**",
      "**/id_rsa",
      "**/id_dsa",
      "**/id_ecdsa",
      "**/id_ed25519",
      "**/.aws/**",
      "**/.azure/**",
      "**/.config/gcloud/**",
      "**/.netrc",
      "**/.npmrc",
      "**/.pypirc"
    ],
    "allowed_paths": [],
    "sandbox": {
      "mode": "local"
    },
    "log_all_commands": true,
    "acp_approval_timeout": 0.0
  },
  "tui": {
    "theme": "default",
    "layout": {}
  },
  "guardrails": {
    "max_tokens_recoveries": 2,
    "max_repeated_tool_steps": 3,
    "reserve_tokens": 512,
    "reserve_cost_fraction": 0.1
  },
  "max_steps": 50,
  "timeout": 0.0,
  "max_retries": 3,
  "streaming": true,
  "context_window": 1000000,
  "context_strategy": "sliding_window",
  "token_budget": 500000,
  "cost_limit": 5.0,
  "token_warning_threshold": 0.8,
  "cost_warning_threshold": 0.8,
  "session_dir": ".agent/sessions",
  "project_rules_dir": ".agent",
  "log_level": "WARNING"
}
